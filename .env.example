# ── Demo mode (default: true) ─────────────────────────────────────────────────
# When true, the whole app runs off local seed data (no backend needed).
# Flip to false once your Spring Boot API is running.
VITE_DEMO_MODE=true

# ── Real backend URL ──────────────────────────────────────────────────────────
# Only used when VITE_DEMO_MODE=false
VITE_API_BASE_URL=https://localhost:8080/api
